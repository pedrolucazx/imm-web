# NPM Configuration
# Ensures consistent behavior across all environments

# Use strict semver
save-prefix=^

# Disable audit on install (can be run separately)
ignore-scripts=false

# Use the npm registry
registry=https://registry.npmjs.org/

# Ensure workspaces work correctly
workspaces-update=false

# Suppress warnings from commitizen passing legacy env vars (version-commit-hooks, argv, etc.)
# Errors are still shown — only "warn" level messages are hidden
loglevel=error
